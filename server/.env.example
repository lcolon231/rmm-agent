# Copy to .env and fill in. Never commit the real .env.

ENVIRONMENT=development
DEBUG=true

# PostgreSQL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://rmm:rmm@localhost:5432/rmm

# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

ACCESS_TOKEN_EXPIRE_MINUTES=60

# Path to the Ed25519 private key created by scripts/gen_command_keys.py
COMMAND_SIGNING_KEY_PATH=command_signing_key.pem
# Optional JSON registry for staged key activation/overlap/retirement.
# COMMAND_SIGNING_KEYRING_PATH=command_keyring.json
COMMAND_SIGNING_KEY_ID=default

HEARTBEAT_INTERVAL_SECONDS=60
OFFLINE_AFTER_MISSED=3
